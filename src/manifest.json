{
  "manifest_version": 3,
  "name": "Яндекс Книги — Загрузчик",
  "version": "1.4",
  "description": "Скачивайте книги и аудиокниги с books.yandex.ru и bookmate.com в форматах EPUB, FB2 и M4A.",
  "permissions": [
    "cookies",
    "downloads",
    "activeTab",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://*.bookmate.com/*",
    "https://books.yandex.ru/*",
    "https://*.yandex.net/*",
    "https://*.yandexcloud.net/*",
    "https://audio.bookmate.ru/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://*.bookmate.com/*",
        "https://books.yandex.ru/*"
      ],
      "js": ["content.js"]
    }
  ],
  "icons": {
    "16":  "icon16.png",
    "48":  "icon48.png",
    "128": "icon128.png"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Яндекс Книги — Загрузчик",
    "default_icon": {
      "16":  "icon16.png",
      "48":  "icon48.png",
      "128": "icon128.png"
    }
  }
}
